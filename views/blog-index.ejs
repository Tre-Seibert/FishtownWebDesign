<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog | Fishtown Web Design</title>
    <meta name="description" content="Explore the Fishtown Web Design blog for expert insights on web development, design trends, and digital solutions. Stay updated with tips, tutorials, and industry news from our Philadelphia-based team.">
    <% if (typeof categorySlug !== 'undefined' && categorySlug) { %>
    <link rel="canonical" href="https://www.fishtownwebdesign.com/blog/category/<%= categorySlug %>" />
    <% } else { %>
    <link rel="canonical" href="https://www.fishtownwebdesign.com/blog" />
    <% } %>
    <meta property="og:title" content="Blog | Fishtown Web Design">
    <meta property="og:description" content="Insights, tips, and updates on web design, SEO, and web development.">
    <meta property="og:url" content="https://www.fishtownwebdesign.com/blog">

    <!-- CSS Imports -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/blog-index.css">
    <link rel="stylesheet" href="/public/css/core.css">

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="16x16" href="/public/content/home/favicon_io/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/public/content/home/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/public/content/home/favicon_io/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/public/content/home/favicon_io/android-chrome-512x512.png">
    <link rel="apple-touch-icon" href="/public/content/home/favicon_io/apple-touch-icon.png">
    <link rel="icon" href="/public/content/home/favicon_io/favicon.ico">
</head>
<body>
    <div class="page-wrapper">
        <!-- Top Banner -->
        <div class="cs-topper-card">
            <div class="top-banner">
                NOW ACCEPTING NEW CLIENTS.
            </div>
        </div>

        <!-- ============================================ -->
    <!--                 Navigation                   -->
    <!-- ============================================ -->

    <%- include('partials/site-nav', { activeSection: 'blog' }) %>

    <!-- ============================================ -->
    <!--                 Blog Hero                    -->
    <!-- ============================================ -->

    <section id="blog-hero-2149">
        <div class="cs-container">
            <div class="cs-content">
                <span class="cs-topper">Blog & News</span>
                <h1 class="cs-title">Case Studies, News & <strong>Insights</strong></h1>
                <p class="cs-text">
                    Stay updated with the latest web design trends, performance optimization tips, and insights from our Philadelphia-based team. Explore case studies, design best practices, and industry news to help your business succeed online.
                </p>
            </div>
        </div>
        <!-- Background Pattern -->
        <picture class="cs-background">
            <source media="(max-width: 600px)" srcset="/public/content/svgs/stripes.svg">
            <source media="(min-width: 601px)" srcset="/public/content/svgs/stripes.svg">
            <img decoding="async" src="/public/content/svgs/stripes.svg" alt="" width="1920" height="907" aria-hidden="true">
        </picture>
    </section>

    <!-- ============================================ -->
    <!--              Blog Categories                  -->
    <!-- ============================================ -->

    <section id="blog-categories-2149">
        <div class="cs-container">
            <div class="cs-content">
                <span class="cs-topper">Browse by Category</span>
                <h2 class="cs-title">Explore Our <strong>Content</strong></h2>
            </div>
            <ul class="cs-category-group">
                <li class="cs-category-item">
                    <a href="/blog" class="cs-category-button <%= !selectedCategory ? 'cs-active' : '' %>">
                        <h3 class="cs-category-title">All Posts</h3>
                        <p class="cs-category-text">View all our blog posts</p>
                    </a>
                </li>
                <% categories.forEach(category => { 
                    const categorySlug = category.toLowerCase().replace(/\s+/g, '-').replace(/[()]/g, '').replace(/&/g, 'and');
                %>
                <li class="cs-category-item">
                    <a href="/blog/category/<%= categorySlug %>" class="cs-category-button <%= selectedCategory === category ? 'cs-active' : '' %>">
                        <h3 class="cs-category-title"><%= category %></h3>
                        <p class="cs-category-text">Explore <%= category %></p>
                    </a>
                </li>
                <% }); %>
            </ul>
        </div>
    </section>

    <!-- ============================================ -->
    <!--              Blog Posts Grid                  -->
    <!-- ============================================ -->

    <section id="blog-posts-2149">
        <div class="cs-container">
            <% if (posts && posts.length > 0) { %>
                <ul class="cs-card-group">
                    <% posts.forEach((post, index) => { %>
                        <li class="cs-item <%= index === 0 ? 'cs-item-featured' : '' %>">
                            <% if (post.featuredImage) { %>
                                <picture class="cs-picture">
                                    <source media="(max-width: 600px)" srcset="<%= post.featuredImage.mobile %>">
                                    <source media="(min-width: 601px)" srcset="<%= post.featuredImage.desktop %>">
                                    <img 
                                        loading="lazy" 
                                        decoding="async" 
                                        src="<%= post.featuredImage.default %>" 
                                        alt="<%= post.title %>" 
                                        width="411" 
                                        height="320">
                                </picture>
                            <% } %>
                            <div class="cs-flex">
                                <div class="cs-info-wrapper">
                                    <span class="cs-date">
                                        <% 
                                            const date = new Date(post.publishedDate);
                                            const month = date.getMonth() + 1;
                                            const day = date.getDate();
                                        %>
                                        <%= month %><br><%= day %>
                                    </span>
                                    <span class="cs-category">
                                        <img class="cs-icon" loading="lazy" decoding="async" src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/folder-green.svg" alt="icon" width="20" height="20" aria-hidden="true">
                                        <%= post.category || 'Blog' %>
                                    </span>
                                </div>
                                <div class="cs-link">
                                    <h3 class="cs-h3">
                                        <a href="/blog/<%= post.slug %>" class="title-link">
                                            <%= post.title %>
                                        </a>
                                    </h3>
                                    <p class="cs-item-text"><%= post.excerpt || 'No preview available.' %></p>
                                    <a href="/blog/<%= post.slug %>" class="cs-read-more">
                                        Read More
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <div class="cs-content">
                    <p class="no-posts">No blog posts available at this time.</p>
                </div>
            <% } %>
        </div>
    </section>

    <!-- ============================================ -->
    <!--                 Footer                       -->
    <!-- ============================================ -->

    <footer id="cs-footer-2412">
        <div class="cs-container cs-container-top">
            <!-- Logo -->
             <picture>
                <source media="(max-width: 600px)" srcset="/public/content/home/footer-logo-m.webp">
                <source media="(min-width: 601px)" srcset="/public/content/home/footer-logo.webp">
                <img loading="lazy" src="/public/content/home/footer-logo.png" id="footer-logo" alt="Fishtown Logo" width="216" height="128">
            </picture>
            <!--Quick Links-->
            <div class="cs-quick-links">
                <ul class="cs-ul">
                    <li class="cs-li">
                        <a class="cs-link" href="/about">About</a>
                    </li>
                    <li class="cs-li">
                        <a class="cs-link" href="/pricing">Pricing</a>
                    </li>
                    <li class="cs-li">
                        <a class="cs-link" href="/web-design">Web Design</a>
                    </li>
                    <li class="cs-li">
                        <a class="cs-link" href="/seo">SEO</a>
                    </li>
                    <li class="cs-li">
                        <a class="cs-link" href="/contact">Contact</a>
                    </li>
                </ul>
            </div>
            <div class="cs-wrapper">
                <!--Subscribtion Form-->
                <div class="cs-subscribe">
                    <h2 class="cs-header">Subscribe for Special Offers & Newsletters</h2>
                    <form class="cs-form" name="Subscription Form" method="post">
                        <input class="cs-input cs-text" type="email" id="cs-subscribe-2412" name="Subscribe" placeholder="Email Address">
                        <button class="cs-button-solid cs-submit" type="submit">
                            <img class="cs-icon" src="https://nyc3.digitaloceanspaces.com/csimages2/Images/Icons/paperplane.svg" alt="submit my email and subcribe" width="40" height="40" decoding="async" loading="lazy">
                        </button>
                    </form>
                </div>
                <div class="cs-bottom">
                    <!--Social-->
                    <div class="cs-social">
                        <a href="https://www.facebook.com/profile.php?id=61570913623739" class="cs-social-link" target="_blank" rel="noopener" aria-label="visit facebook">
                            <img class="cs-social-icon" src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/face-white1.svg" alt="facebook" loading="lazy" decoding="async" width="12" height="12">
                        </a>
                        <a href="https://instagram.com/fishtownwebdesign" class="cs-social-link" target="_blank" rel="noopener" aria-label="visit instagram">
                            <img class="cs-social-icon" src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/instagram.svg" alt="instagram" loading="lazy" decoding="async" width="12" height="12">
                        </a>
                    </div>
                    <!--Legal-->
                    <div class="cs-legal">
                        <a href="/tos" class="cs-legal-link cs-link">Terms & Conditions</a>
                        <span class="cs-divider" aria-hidden="true">|</span>
                        <a href="/pp" class="cs-legal-link cs-link">Privacy Policy</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="cs-credit">
            <span class="cs-ip cs-text">© 2026 Fishtown Web Design. All rights reserved.</span>
        </div>
        <svg class="cs-curve" aria-hidden="true" width="1920" height="1" viewBox="0 0 1920 1" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="1920" height="1" fill="var(--overlayBG)"/>
        </svg>
    </footer>
    </div>

    <script>
        // Update copyright year
        document.getElementById("current-year").textContent = new Date().getFullYear();

        // Mobile navigation
        const CSbody = document.querySelector('body');
        const CSnavbarMenu = document.querySelector('#cs-navigation');
        const CShamburgerMenu = document.querySelector('#cs-navigation .cs-toggle');

        CShamburgerMenu.addEventListener('click', function() {
            CShamburgerMenu.classList.toggle('cs-active');
            CSnavbarMenu.classList.toggle('cs-active');
            CSbody.classList.toggle('cs-open');
            ariaExpanded();
        });

        function ariaExpanded() {
            const csUL = document.querySelector('#cs-expanded');
            const csExpanded = csUL.getAttribute('aria-expanded');
            csUL.setAttribute('aria-expanded', csExpanded === 'false' ? 'true' : 'false');
        }

        // Mobile dropdowns
        const dropDowns = Array.from(document.querySelectorAll('#cs-navigation .cs-dropdown'));
        dropDowns.forEach(item => {
            item.addEventListener('click', () => item.classList.toggle('cs-active'));
        });

    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P9ZFLQPT8E"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-P9ZFLQPT8E');
    </script>
</body>
</html>