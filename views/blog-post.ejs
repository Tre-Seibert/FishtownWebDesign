<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Meta Tags -->
    <title><%= post.title %> | Fishtown Web Design Blog</title>
    <meta name="description" content="<%= post.excerpt %>">
    <link rel="canonical" href="https://fishtownwebdesign.com/blog/<%= post.slug %>" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article">
    <meta property="og:title" content="<%= post.title %> | Fishtown Web Design Blog">
    <meta property="og:description" content="<%= post.excerpt %>">
    <meta property="og:url" content="https://fishtownwebdesign.com/blog/<%= post.slug %>">
    <meta property="og:image" content="<%= post.featuredImage || 'https://fishtownwebdesign.com/public/content/home/fish.png' %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="article:published_time" content="<%= post.publishedAt %>">
    <meta property="article:author" content="Fishtown Web Design">
    <meta property="article:section" content="<%= post.category %>">
    <meta property="article:tag" content="<%= post.tags.join(', ') %>">

    <!--CSS Imports-->
    <link rel="stylesheet" href="/public/css/core.css">
    <link rel="stylesheet" href="/public/css/internet-marketing-fishtown.css">

    <!--Favicons-->
    <link rel="icon" type="image/png" sizes="16x16" href="https://fishtownwebdesign.com/public/content/home/favicon_io/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="https://fishtownwebdesign.com/public/content/home/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="https://fishtownwebdesign.com/public/content/home/favicon_io/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="https://fishtownwebdesign.com/public/content/home/favicon_io/android-chrome-512x512.png">
    <link rel="apple-touch-icon" href="https://fishtownwebdesign.com/public/content/home/favicon_io/apple-touch-icon.png">
    <link rel="icon" href="https://fishtownwebdesign.com/public/content/home/favicon_io/favicon.ico">

    <style>
        .about-text p {
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 20px;
            font-family: "Montserrat";
        }
    </style>
</head>

<body>
    <!-- Black Banner at the top -->
    <div class="top-banner">
        EXPERT INTERNET MARKETING & SEO SERVICES IN FISHTOWN
    </div>

    <nav class="navbar navbar-light navbar-custom">
        <div class="container-fluid">
            <!-- Logo and Menu Icon -->
            <a class="navbar-brand" href="https://fishtownwebdesign.com/">
                <picture>
                    <source media="(max-width: 600px)" srcset="https://fishtownwebdesign.com/public/content/home/logo-m.webp">
                    <source media="(min-width: 601px)" srcset="https://fishtownwebdesign.com/public/content/home/logo.webp">
                    <img 
                        src="/public/content/home/logo.png"
                        alt="Fishtown Web Design Logo" 
                        loading="lazy" 
                        decoding="async"
                        id="logo"
                        width="130px"
                        height="46.29px">
                </picture>
            </a>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav"
                aria-controls="navbarNav"
                aria-expanded="false"
                aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="https://fishtownwebdesign.com/">home</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            about
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
                            <li><a class="dropdown-item" href="https://fishtownwebdesign.com/about">about us</a></li>
                            <li><a class="dropdown-item" href="https://fishtownwebdesign.com/faq">faq</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="https://fishtownwebdesign.com/pricing">pricing</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="https://fishtownwebdesign.com/contact">contact</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="https://fishtownwebdesign.com/blog">blog</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="about-section">
        <!-- About Banner with drips -->
        <div class="about-banner">
            <h1><%= post.title %></h1>
        </div>

    <!-- Main Content Section -->
    <div class="content-wrapper">
        <!-- Text Content -->
        <div class="about-text">
            <div class="blog-content">
                <% post.content.forEach(function(block) { %>

                    <% if (block.type === 'heading') { %>
                        <h<%= block.level %>><%= block.children[0].text %></h<%= block.level %>>
                    <% } else if (block.type === 'paragraph') { %>
                        <p><%= block.children.map(child => child.text).join(" ") %></p>
                    <% } else if (block.type === 'list') { %>
                        <ul>
                            <% block.children.forEach(function(listItem) { %>
                                <li><%= listItem.children.map(child => child.text).join(" ") %></li>
                            <% }); %>
                        </ul>
                    <% } else if (block.type === 'code') { %>
                        <pre><code class="language-<%= block.language || 'plaintext' %>"><%= block.children[0].text %></code></pre>
                    <% } else if (block.type === 'quote') { %>
                        <blockquote><%= block.children[0].text %></blockquote>
                    <% } %>
    
                <% }); %>
            <a href="/blog" class="cs-button-solid">Back to Blog</a> | <a href="/" class="cs-button-solid">Home</a>
        </div>
    </div>


    <!-- Footer Section -->
    <footer class="footer text-center py-4">
        <p>© <span id="current-year"></span> Fishtown Web Design. All rights reserved.</p>
        <picture>
            <source media="(max-width: 600px)" srcset="https://fishtownwebdesign.com/public/content/home/fish-m.webp">
            <source media="(min-width: 601px)" srcset="https://fishtownwebdesign.com/public/content/home/fish.webp">
            <img loading="lazy" src="/public/content/home/fish.png" id="fish" alt="Fishtown Logo">
        </picture>
        <p><a href="https://www.facebook.com/profile.php?id=61570913623739">Facebook</a> | <a href="https://instagram.com/fishtownwebdesign">Instagram</a></p>
        <p><a id="tos" href="https://fishtownwebdesign.com/terms-of-service">Terms Of Service</a><a id="pp" href="https://fishtownwebdesign.com/privacy-policy">Privacy Policy</a></p>
    </footer>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P9ZFLQPT8E"></script>
    <script async>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-P9ZFLQPT8E');
    </script>

    <script defer>
        // Set the current year dynamically
        document.getElementById("current-year").textContent = new Date().getFullYear();
    </script>
</body>
</html>